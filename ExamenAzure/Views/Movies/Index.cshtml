@model IEnumerable<ExamenAzure.Models.Movie>

@{
    ViewData["Title"] = "Каталог фільмів";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🍿 Azure Cinema Hub — Каталог</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Додати новий фільм</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Каталог порожній. Будь ласка, додайте свій перший фільм!</div>
    }
    else
    {
        <div class="row">
            @foreach (var movie in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@movie.Title</h5>
                            <p class="card-text text-muted flex-grow-1">@movie.Description</p>
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-success w-100">▶️ Дивитися</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
