@model ExamenAzure.Models.Movie

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <h2>@Model.Title</h2>
    <p class="text-muted">Додано: @Model.CreatedAt.ToLocalTime().ToString("g")</p>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <video controls width="100%" controlsList="nodownload" class="border rounded bg-dark">
                <source src="@ViewBag.SasVideoUrl" type="video/mp4">
                Ваш браузер не підтримує відтворення відео.
            </video>
        </div>
        <div class="col-md-4">
            <h5>Опис фільму</h5>
            <p style="white-space: pre-line;">@Model.Description</p>
            <a asp-action="Index" class="btn btn-secondary mt-3">Назад до каталогу</a>
        </div>
    </div>
</div>
